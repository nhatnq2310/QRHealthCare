<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base app theme — Compose handles actual theming via QrHealthcareTheme -->
    <style name="Theme.QrHealthcare" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- Splash theme — applied to MainActivity until installSplashScreen() hands off -->
    <style name="Theme.QrHealthcare.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/splash_bg</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="postSplashScreenTheme">@style/Theme.QrHealthcare</item>
    </style>
</resources>
