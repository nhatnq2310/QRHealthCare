        android:fillColor="#FFFFFF"
        android:pathData="M49,36 h6 a2,2 0 0 1 2,2 v36 a2,2 0 0 1 -2,2 h-6 a2,2 0 0 1 -2,-2 v-36 a2,2 0 0 1 2,-2 z"/>
