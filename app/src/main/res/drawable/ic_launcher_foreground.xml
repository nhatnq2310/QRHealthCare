    <path
        android:fillColor="#FFFFFF"
        android:pathData="M36,49 h36 a2,2 0 0 1 2,2 v6 a2,2 0 0 1 -2,2 h-36 a2,2 0 0 1 -2,-2 v-6 a2,2 0 0 1 2,-2 z"/>
    <!-- Vertical bar -->
