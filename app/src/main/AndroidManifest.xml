<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Required for API calls -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Required for QR camera scanning (future feature) -->
    <uses-permission android:name="android.permission.CAMERA" />
    <!-- Required to show FCM push notifications on Android 13+ (family scan alerts) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- NOTE: no location permission needed here — the scanner's phone shares
         location via their mobile BROWSER (the public scan page's own
         navigator.geolocation prompt), not through this Android app. -->

    <application
        android:name=".QrHealthcareApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.QrHealthcare"
        android:networkSecurityConfig="@xml/network_security_config">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.QrHealthcare.Splash"
            android:windowSoftInputMode="adjustResize">

            <!-- App launcher intent -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Deep link: qrhealthcare://profile/QRH-A1B2 -->
            <!-- This is triggered when user scans a QR code with our app scheme -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data
                    android:scheme="qrhealthcare"
                    android:host="profile" />
            </intent-filter>

            <!-- Web deep link: https://qrhealthcare.com/qr/QRH-A1B2 -->
            <!-- Uncomment when you have a real domain and configure Digital Asset Links -->
            <!--
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data
                    android:scheme="https"
                    android:host="qrhealthcare.com"
                    android:pathPrefix="/qr/" />
            </intent-filter>
            -->

        </activity>

        <!-- Family scan-notification push service — see app/FCM_SETUP.md.
             Safe to leave declared even before Firebase is configured; it
             simply never receives anything until google-services.json is added. -->
        <service
            android:name=".fcm.QrHealthcareFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>
    </application>
</manifest>
