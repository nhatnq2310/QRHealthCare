# Copy this to backend/.env and edit if needed.
# .env is gitignored — never commit real secrets.

# MongoDB — append a database name to your connection string.
# Local: mongodb://127.0.0.1:27017/qrhealthcare
# Atlas: mongodb+srv://user:pass@cluster.mongodb.net/qrhealthcare
MONGODB_URI=mongodb+srv://nhatnhatnhat2310_db_user:ZiekSVFYSB41hQ9N@cluster0.yugqeei.mongodb.net/?appName=Cluster0
# JWT signing key — generate a long random string for production.
# Quick generator: openssl rand -hex 64
JWT_SECRET=SE160985!
JWT_EXPIRES_IN=30d

# Port the API listens on. Server binds to 0.0.0.0 so phones on the same
# WiFi can reach it via your computer's LAN IP.
PORT=4000

# CORS — set to "*" in dev. In production list your real origins.
CORS_ORIGIN=*
